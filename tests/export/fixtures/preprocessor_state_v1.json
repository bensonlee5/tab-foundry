{
  "feature_order_policy": "lexicographic_f_columns",
  "missing_value_policy": {
    "strategy": "train_mean",
    "all_nan_fill": 0.0
  },
  "classification_label_policy": {
    "mapping": "train_only_remap",
    "unseen_test_label": "error"
  },
  "dtype_policy": {
    "features": "float32",
    "classification_labels": "int64",
    "regression_targets": "float32"
  }
}
